<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Default: allow cleartext (HTTP) traffic. User can add local LLM providers on HTTP. -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
